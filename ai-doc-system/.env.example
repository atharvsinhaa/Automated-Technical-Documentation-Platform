# ── Server ───────────────────────────────────────────────────
PORT=8000                              # Port the API listens on (PaaS sets this dynamically)
CORS_ORIGINS=http://localhost:4200     # Comma-separated list of allowed origins

# ── Ollama (LLM) ────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434     # Ollama server URL
OLLAMA_MODEL=llama3                    # Default model when use_llm=true

# ── Pipeline output ─────────────────────────────────────────
OUTPUT_DIR=./outputs                   # Default output directory for pipeline artefacts

# ── Database ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017    # MongoDB connection string
MONGO_DB_NAME=docai                    # Default database name
